{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-sdl",
  "tests": [
    {
      "id": "binary__compile_fail__sdl2_init_too_few_args",
      "level": "sdl",
      "category": "compile_fail",
      "inputs": [
        "cases/binary__compile_fail__sdl2_init_too_few_args.c"
      ],
      "args": [
        "-std=c99"
      ],
      "pkg_config_modules": [
        "sdl2"
      ],
      "skip_if": {
        "missing_tools": [
          "pkg-config"
        ],
        "missing_pkg_config_modules": [
          "sdl2"
        ]
      },
      "expect_output_contains": [
        "too few arguments"
      ],
      "timeout_sec": 10,
      "resource_profile": "default"
    },
    {
      "id": "binary__link_fail__sdl2_missing_symbol",
      "level": "sdl",
      "category": "link_fail",
      "inputs": [
        "cases/binary__link_fail__sdl2_missing_symbol.c"
      ],
      "args": [
        "-std=c99"
      ],
      "pkg_config_modules": [
        "sdl2"
      ],
      "skip_if": {
        "missing_tools": [
          "pkg-config"
        ],
        "missing_pkg_config_modules": [
          "sdl2"
        ]
      },
      "expect_output_contains": [
        "undefined"
      ],
      "timeout_sec": 10,
      "resource_profile": "default"
    }
  ]
}
