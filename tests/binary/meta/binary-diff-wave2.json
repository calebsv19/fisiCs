{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-diff",
  "tests": [
    {
      "id": "binary__runtime__diff_clang_argv_count",
      "level": "diff",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__argv_count.c"
      ],
      "args": [
        "-std=c99"
      ],
      "run_args": [
        "one",
        "two",
        "three"
      ],
      "expected_stdout": "expect/binary__runtime__argv_count.stdout",
      "expect_exit": 0,
      "differential_with": "clang",
      "skip_if": {
        "missing_tools": [
          "clang"
        ]
      },
      "timeout_sec": 10,
      "resource_profile": "default"
    },
    {
      "id": "binary__runtime__diff_clang_stdin_byte_count",
      "level": "diff",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__stdin_byte_count.c"
      ],
      "args": [
        "-std=c99"
      ],
      "run_stdin": "abcdef\n",
      "expected_stdout": "expect/binary__runtime__stdin_byte_count.stdout",
      "expect_exit": 0,
      "differential_with": "clang",
      "skip_if": {
        "missing_tools": [
          "clang"
        ]
      },
      "timeout_sec": 10,
      "resource_profile": "default"
    },
    {
      "id": "binary__runtime__diff_clang_env_echo",
      "level": "diff",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__env_echo.c"
      ],
      "args": [
        "-std=c99"
      ],
      "run_env": {
        "BINARY_SMOKE_ENV": "phaseA"
      },
      "expected_stdout": "expect/binary__runtime__env_echo.stdout",
      "expect_exit": 0,
      "differential_with": "clang",
      "skip_if": {
        "missing_tools": [
          "clang"
        ]
      },
      "timeout_sec": 10,
      "resource_profile": "default"
    }
  ]
}
