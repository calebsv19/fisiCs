{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-sdl",
  "tests": [
    {
      "id": "binary__runtime__diff_clang_sdl2_rect_ops_matrix",
      "level": "sdl",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__sdl2_rect_ops_matrix.c"
      ],
      "args": [
        "-std=c99"
      ],
      "pkg_config_modules": [
        "sdl2"
      ],
      "skip_if": {
        "missing_tools": [
          "pkg-config"
        ],
        "missing_pkg_config_modules": [
          "sdl2"
        ]
      },
      "run_env": {
        "SDL_VIDEODRIVER": "dummy",
        "SDL_AUDIODRIVER": "dummy"
      },
      "expect_exit": 0,
      "expected_stdout": "expect/binary__runtime__sdl2_rect_ops_matrix.stdout",
      "timeout_sec": 10,
      "resource_profile": "default",
      "differential_with": "clang"
    },
