{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-sdl",
  "tests": [
    {
      "id": "binary__runtime__sdl2_renderer_hidden_software_clear",
      "level": "sdl",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__sdl2_renderer_hidden_software_clear.c"
      ],
      "args": [
        "-std=c99"
      ],
      "pkg_config_modules": [
        "sdl2"
      ],
      "skip_if": {
        "missing_env": [
          "ENABLE_SDL_RENDERER_TESTS"
        ],
        "missing_tools": [
          "pkg-config"
        ],
        "missing_pkg_config_modules": [
          "sdl2"
        ]
      },
      "run_env": {
        "SDL_VIDEODRIVER": "dummy",
        "SDL_AUDIODRIVER": "dummy",
        "SDL_RENDER_DRIVER": "software"
      },
      "expect_exit": 0,
      "expected_stdout": "expect/binary__runtime__sdl2_renderer_hidden_software_clear.stdout",
      "timeout_sec": 10,
      "resource_profile": "default"
    },
    {
      "id": "binary__runtime__sdl2_renderer_texture_lock_cycle",
      "level": "sdl",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__sdl2_renderer_texture_lock_cycle.c"
      ],
      "args": [
        "-std=c99"
      ],
      "pkg_config_modules": [
        "sdl2"
      ],
      "skip_if": {
        "missing_env": [
          "ENABLE_SDL_RENDERER_TESTS"
        ],
        "missing_tools": [
          "pkg-config"
        ],
        "missing_pkg_config_modules": [
          "sdl2"
        ]
      },
      "run_env": {
        "SDL_VIDEODRIVER": "dummy",
        "SDL_AUDIODRIVER": "dummy",
        "SDL_RENDER_DRIVER": "software"
      },
      "expect_exit": 0,
      "expected_stdout": "expect/binary__runtime__sdl2_renderer_texture_lock_cycle.stdout",
      "timeout_sec": 10,
      "resource_profile": "default"
    }
  ]
}
