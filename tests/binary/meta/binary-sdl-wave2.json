{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-sdl",
  "tests": [
    {
      "id": "binary__runtime__sdl2_headless_init_quit",
      "level": "sdl",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__sdl2_headless_init_quit.c"
      ],
      "args": [
        "-std=c99"
      ],
      "pkg_config_modules": [
        "sdl2"
      ],
      "skip_if": {
        "missing_tools": [
          "pkg-config"
        ],
        "missing_pkg_config_modules": [
          "sdl2"
        ]
      },
      "run_env": {
        "SDL_VIDEODRIVER": "dummy",
        "SDL_AUDIODRIVER": "dummy"
      },
      "expect_exit": 0,
      "expected_stdout": "expect/binary__runtime__sdl2_headless_init_quit.stdout",
      "timeout_sec": 10,
      "resource_profile": "default"
    },
