      "timeout_sec": 10,
      "resource_profile": "default"
    },
    {
      "id": "binary__link_fail__abi_duplicate_fn_table",
      "level": "abi",
      "category": "link_fail",
      "inputs": [
        "cases/binary__link_fail__abi_duplicate_fn_table_a.c",
