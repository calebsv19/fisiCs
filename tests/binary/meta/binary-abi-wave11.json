{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-abi",
  "tests": [
    {
      "id": "binary__link_fail__abi_undefined_fnptr",
      "level": "abi",
      "category": "link_fail",
      "inputs": [
        "cases/binary__link_fail__abi_undefined_fnptr_main.c",
        "cases/binary__link_fail__abi_undefined_fnptr_helper.c"
      ],
      "args": [
        "-std=c99"
      ],
      "expect_output_contains": [
        "undefined",
        "abi_missing_leaf"
      ],
      "timeout_sec": 10,
      "resource_profile": "default"
    },
    {
      "id": "binary__link_fail__abi_undefined_struct_return",
      "level": "abi",
      "category": "link_fail",
      "inputs": [
        "cases/binary__link_fail__abi_undefined_struct_return_main.c",
        "cases/binary__link_fail__abi_undefined_struct_return_helper.c"
      ],
      "args": [
        "-std=c99"
      ],
      "expect_output_contains": [
        "undefined",
        "abi_missing_pair_leaf"
      ],
      "timeout_sec": 10,
      "resource_profile": "default"
    },
    {
      "id": "binary__link_fail__abi_duplicate_fn_dispatch",
      "level": "abi",
      "category": "link_fail",
      "inputs": [
        "cases/binary__link_fail__abi_duplicate_fn_dispatch_a.c",
        "cases/binary__link_fail__abi_duplicate_fn_dispatch_b.c"
      ],
      "args": [
        "-std=c99"
      ],
      "expect_output_contains": [
        "duplicate symbol",
