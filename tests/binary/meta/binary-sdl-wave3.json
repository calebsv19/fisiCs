      "id": "binary__runtime__sdl2_hidden_window_create_destroy",
      "level": "sdl",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__sdl2_hidden_window_create_destroy.c"
      ],
      "args": [
        "-std=c99"
      ],
      "pkg_config_modules": [
        "sdl2"
      ],
      "skip_if": {
        "missing_tools": [
          "pkg-config"
        ],
        "missing_pkg_config_modules": [
          "sdl2"
        ]
      },
      "run_env": {
        "SDL_VIDEODRIVER": "dummy",
        "SDL_AUDIODRIVER": "dummy"
      },
      "expect_exit": 0,
      "expected_stdout": "expect/binary__runtime__sdl2_hidden_window_create_destroy.stdout",
      "timeout_sec": 10,
      "resource_profile": "default"
    },
