{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-diff",
  "tests": [
    {
      "id": "binary__runtime__diff_clang_abi_mixed_return_pressure",
      "level": "diff",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__abi_mixed_return_pressure.c"
      ],
      "args": [
        "-std=c99"
      ],
      "expected_stdout": "expect/binary__runtime__abi_mixed_return_pressure.stdout",
      "expect_exit": 0,
