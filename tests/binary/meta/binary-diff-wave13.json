{
  "version": 1,
  "suite": "binary",
  "bucket": "binary-diff",
  "tests": [
    {
      "id": "binary__runtime__diff_clang_return_zero",
      "level": "diff",
      "category": "runtime",
      "inputs": [
        "cases/binary__runtime__return_zero.c"
      ],
      "args": [
        "-std=c99"
      ],
      "expect_exit": 0,
      "differential_with": "clang",
      "skip_if": {
        "missing_tools": [
          "clang"
        ]
      },
      "timeout_sec": 10,
      "resource_profile": "smoke"
    },
    {
