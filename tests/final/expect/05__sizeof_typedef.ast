AST:
PROGRAM
  TYPEDEF
        TYPE: int
        Alias:     IDENTIFIER T
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = 
            SIZEOF
                            PARSED_TYPE T
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = 
            SIZEOF
                            IDENTIFIER x
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          IDENTIFIER b
