PROGRAM
  STRUCT
        Name:     IDENTIFIER Pair
    VAR_DECL
      TYPE: int
      IDENTIFIER a
    VAR_DECL
      TYPE: int
      IDENTIFIER b
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: struct Pair
        IDENTIFIER p
            = NUMBER_LITERAL 10

            = NUMBER_LITERAL 20

      RETURN
        BINARY EXPRESSION '+'
          DOT_ACCESS '.'
            IDENTIFIER p
            FIELD a
          DOT_ACCESS '.'
            IDENTIFIER p
            FIELD b
