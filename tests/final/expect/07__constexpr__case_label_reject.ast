AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER label
          = NUMBER_LITERAL 2
      SWITCH
        NUMBER_LITERAL 0
        CASE
          IDENTIFIER label
          RETURN
            NUMBER_LITERAL 1
        CASE
          DEFAULT
          RETURN
            NUMBER_LITERAL 0
