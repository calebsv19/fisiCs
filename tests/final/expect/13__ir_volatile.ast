PROGRAM
  VAR_DECL
    TYPE: volatile int
    IDENTIFIER g
      = NUMBER_LITERAL 0
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER l
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = IDENTIFIER l
      ASSIGNMENT (=)
        IDENTIFIER g
        IDENTIFIER x
      ASSIGNMENT (=)
        IDENTIFIER l
        NUMBER_LITERAL 2
      RETURN
        BINARY EXPRESSION '+'
          BINARY EXPRESSION '+'
            IDENTIFIER g
            IDENTIFIER x
          IDENTIFIER l
