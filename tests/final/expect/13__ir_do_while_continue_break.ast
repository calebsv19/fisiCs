AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER i
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER acc
          = NUMBER_LITERAL 0
      DO_WHILE_LOOP
        BLOCK
          UNARY EXPRESSION '++' (prefix)
            IDENTIFIER i
          IF_STATEMENT
            BINARY EXPRESSION '=='
              IDENTIFIER i
              NUMBER_LITERAL 2
            BLOCK
              CONTINUE
          IF_STATEMENT
            BINARY EXPRESSION '=='
              IDENTIFIER i
              NUMBER_LITERAL 5
            BLOCK
              BREAK
          ASSIGNMENT (+=)
            IDENTIFIER acc
            IDENTIFIER i
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 8
      RETURN
        IDENTIFIER acc
