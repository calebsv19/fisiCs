AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER ub_shift_negative_count
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
      VAR_DECL
        TYPE: int
        IDENTIFIER s
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            BINARY EXPRESSION '<<'
              IDENTIFIER x
              IDENTIFIER s
      IF_STATEMENT
        BINARY EXPRESSION '<'
          IDENTIFIER y
          IDENTIFIER x
        BLOCK
          RETURN
            IDENTIFIER y
      RETURN
        IDENTIFIER x
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 3
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER shift
          = 
            UNARY EXPRESSION '-' (prefix)
              NUMBER_LITERAL 1
      RETURN
        FUNCTION CALL
          IDENTIFIER ub_shift_negative_count
          ARGUMENTS
            IDENTIFIER seed
            IDENTIFIER shift
