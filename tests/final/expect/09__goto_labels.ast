AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 0
      LABEL: start
        UNARY EXPRESSION '++' (postfix)
          IDENTIFIER x
      IF_STATEMENT
        BINARY EXPRESSION '<'
          IDENTIFIER x
          NUMBER_LITERAL 2
        GOTO
          LABEL start
      RETURN
        IDENTIFIER x
