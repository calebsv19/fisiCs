AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER add
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER a
      VAR_DECL
        TYPE: int
        IDENTIFIER b
    BLOCK
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          IDENTIFIER b
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int [3]
        IDENTIFIER arr
            = NUMBER_LITERAL 1

            = NUMBER_LITERAL 2

            = NUMBER_LITERAL 3

      VAR_DECL
        TYPE: int*
        IDENTIFIER p
          = IDENTIFIER arr
      VAR_DECL
        TYPE: int (*)(int, int)
        IDENTIFIER fp
          = IDENTIFIER add
      RETURN
        BINARY EXPRESSION '+'
          ARRAY_ACCESS
            IDENTIFIER p
            NUMBER_LITERAL 0
          FUNCTION CALL
            IDENTIFIER fp
            ARGUMENTS
              NUMBER_LITERAL 1
              NUMBER_LITERAL 2
