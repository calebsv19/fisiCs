AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER v
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int*
        IDENTIFIER p
          = 
            UNARY EXPRESSION '&' (prefix)
              IDENTIFIER v
      RETURN
        POINTER_ACCESS '->'
          IDENTIFIER p
          FIELD missing
