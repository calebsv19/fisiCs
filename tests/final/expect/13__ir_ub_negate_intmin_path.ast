AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER ub_negate
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            UNARY EXPRESSION '-' (prefix)
              IDENTIFIER x
      IF_STATEMENT
        BINARY EXPRESSION '=='
          IDENTIFIER y
          IDENTIFIER x
        BLOCK
          RETURN
            IDENTIFIER y
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER y
          NUMBER_LITERAL 1
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = 
            CAST_EXPRESSION
                            CAST TYPE: int
              NUMBER_LITERAL 0x80000000u
      RETURN
        FUNCTION CALL
          IDENTIFIER ub_negate
          ARGUMENTS
            IDENTIFIER seed
