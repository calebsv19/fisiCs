AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 9
      VAR_DECL
        TYPE: int*
        IDENTIFIER p
          = 
            UNARY EXPRESSION '&' (prefix)
              IDENTIFIER x
      RETURN
        BINARY EXPRESSION '-'
          UNARY EXPRESSION '*' (prefix)
            IDENTIFIER p
          NUMBER_LITERAL 9
