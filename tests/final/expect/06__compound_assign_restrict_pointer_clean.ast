AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: static int
    IDENTIFIER bump_pair
    PARAMETERS
      VAR_DECL
        TYPE: int* restrict
        IDENTIFIER left
      VAR_DECL
        TYPE: int* restrict
        IDENTIFIER right
    BLOCK
      ASSIGNMENT (+=)
        UNARY EXPRESSION '*' (prefix)
          IDENTIFIER left
        NUMBER_LITERAL 2
      ASSIGNMENT (-=)
        UNARY EXPRESSION '*' (prefix)
          IDENTIFIER right
        NUMBER_LITERAL 1
      RETURN
        BINARY EXPRESSION '+'
          UNARY EXPRESSION '*' (prefix)
            IDENTIFIER left
          UNARY EXPRESSION '*' (prefix)
            IDENTIFIER right
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 3
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = NUMBER_LITERAL 9
      RETURN
        FUNCTION CALL
          IDENTIFIER bump_pair
          ARGUMENTS
            UNARY EXPRESSION '&' (prefix)
              IDENTIFIER a
            UNARY EXPRESSION '&' (prefix)
              IDENTIFIER b
