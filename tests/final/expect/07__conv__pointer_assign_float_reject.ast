AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int*
        IDENTIFIER p
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: double
        IDENTIFIER d
          = NUMBER_LITERAL 1.5
      ASSIGNMENT (=)
        IDENTIFIER p
        IDENTIFIER d
      RETURN
        BINARY EXPRESSION '!='
          IDENTIFIER p
          NUMBER_LITERAL 0
