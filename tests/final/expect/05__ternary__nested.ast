AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER c
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER v
          = 
            TERNARY_EXPRESSION
              IDENTIFIER a
              TERNARY_EXPRESSION
                IDENTIFIER b
                NUMBER_LITERAL 10
                TERNARY_EXPRESSION
                  IDENTIFIER c
                  NUMBER_LITERAL 20
                  NUMBER_LITERAL 30
              NUMBER_LITERAL 40
      RETURN
        TERNARY_EXPRESSION
          BINARY EXPRESSION '=='
            IDENTIFIER v
            NUMBER_LITERAL 20
          NUMBER_LITERAL 0
          NUMBER_LITERAL 1
