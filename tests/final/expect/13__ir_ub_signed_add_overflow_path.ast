AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER overflow_path
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            BINARY EXPRESSION '+'
              IDENTIFIER x
              NUMBER_LITERAL 1
      IF_STATEMENT
        BINARY EXPRESSION '<'
          IDENTIFIER y
          IDENTIFIER x
        BLOCK
          RETURN
            BINARY EXPRESSION '^'
              IDENTIFIER y
              IDENTIFIER x
      RETURN
        IDENTIFIER y
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 2147483647
      RETURN
        FUNCTION CALL
          IDENTIFIER overflow_path
          ARGUMENTS
            IDENTIFIER seed
