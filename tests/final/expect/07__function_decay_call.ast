AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER add
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER a
      VAR_DECL
        TYPE: int
        IDENTIFIER b
    BLOCK
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          IDENTIFIER b
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER apply
    PARAMETERS
      VAR_DECL
        TYPE: int (*)(int, int) (int, int)
        IDENTIFIER fn
      VAR_DECL
        TYPE: int
        IDENTIFIER x
      VAR_DECL
        TYPE: int
        IDENTIFIER y
    BLOCK
      RETURN
        FUNCTION CALL
          IDENTIFIER fn
          ARGUMENTS
            IDENTIFIER x
            IDENTIFIER y
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      RETURN
        FUNCTION CALL
          IDENTIFIER apply
          ARGUMENTS
            IDENTIFIER add
            NUMBER_LITERAL 2
            NUMBER_LITERAL 5
