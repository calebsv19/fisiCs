AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER ub_add_assign
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      ASSIGNMENT (+=)
        IDENTIFIER x
        NUMBER_LITERAL 1
      IF_STATEMENT
        BINARY EXPRESSION '<'
          IDENTIFIER x
          NUMBER_LITERAL 0
        BLOCK
          RETURN
            IDENTIFIER x
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER x
          NUMBER_LITERAL 1
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 2147483647
      RETURN
        FUNCTION CALL
          IDENTIFIER ub_add_assign
          ARGUMENTS
            IDENTIFIER seed
