AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER signed_value
          = NUMBER_LITERAL 8
      VAR_DECL
        TYPE: unsigned int
        IDENTIFIER unsigned_value
          = NUMBER_LITERAL 1u
      VAR_DECL
        TYPE: int
        IDENTIFIER arith_shift
          = 
            BINARY EXPRESSION '>>'
              IDENTIFIER signed_value
              NUMBER_LITERAL 1
      VAR_DECL
        TYPE: unsigned int
        IDENTIFIER logical_shift
          = 
            BINARY EXPRESSION '<<'
              IDENTIFIER unsigned_value
              NUMBER_LITERAL 3
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER arith_shift
          CAST_EXPRESSION
                        CAST TYPE: int
            IDENTIFIER logical_shift
