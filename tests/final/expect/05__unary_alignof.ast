AST:
PROGRAM
  VAR_DECL
    TYPE: int
    IDENTIFIER align_char
      = 
        ALIGNOF
                    PARSED_TYPE char
  VAR_DECL
    TYPE: int
    IDENTIFIER align_int
      = 
        ALIGNOF
                    PARSED_TYPE int
  VAR_DECL
    TYPE: int
    IDENTIFIER align_double
      = 
        ALIGNOF
                    PARSED_TYPE double
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      RETURN
        BINARY EXPRESSION '+'
          BINARY EXPRESSION '+'
            IDENTIFIER align_char
            IDENTIFIER align_int
          IDENTIFIER align_double
