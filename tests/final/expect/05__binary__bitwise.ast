AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: unsigned int
        IDENTIFIER a
          = NUMBER_LITERAL 0x55u
      VAR_DECL
        TYPE: unsigned int
        IDENTIFIER b
          = NUMBER_LITERAL 0x0fu
      VAR_DECL
        TYPE: unsigned int
        IDENTIFIER c
          = 
            BINARY EXPRESSION '^'
              BINARY EXPRESSION '&'
                IDENTIFIER a
                IDENTIFIER b
              BINARY EXPRESSION '|'
                IDENTIFIER a
                IDENTIFIER b
      RETURN
        TERNARY_EXPRESSION
          BINARY EXPRESSION '=='
            IDENTIFIER c
            NUMBER_LITERAL 0x5au
          NUMBER_LITERAL 0
          NUMBER_LITERAL 1
