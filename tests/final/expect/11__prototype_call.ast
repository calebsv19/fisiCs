AST:
PROGRAM
  FUNCTION DECLARATION
    RETURN TYPE: int
    IDENTIFIER add
    PARAMETERS:
      VAR_DECL
        TYPE: int
        IDENTIFIER a
      VAR_DECL
        TYPE: int
        IDENTIFIER b
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER add
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER a
      VAR_DECL
        TYPE: int
        IDENTIFIER b
    BLOCK
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          IDENTIFIER b
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER ok
          = 
            FUNCTION CALL
              IDENTIFIER add
              ARGUMENTS
                NUMBER_LITERAL 1
                NUMBER_LITERAL 2
      VAR_DECL
        TYPE: int
        IDENTIFIER bad
          = 
            FUNCTION CALL
              IDENTIFIER add
              ARGUMENTS
                NUMBER_LITERAL 1
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER ok
          IDENTIFIER bad
