AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int*
        IDENTIFIER ip
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: double*
        IDENTIFIER dp
          = NUMBER_LITERAL 0
      ASSIGNMENT (=)
