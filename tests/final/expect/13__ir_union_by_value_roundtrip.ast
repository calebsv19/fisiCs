AST:
PROGRAM
  UNION
        Name:     IDENTIFIER Word
    VAR_DECL
      TYPE: int
      IDENTIFIER i
    VAR_DECL
      TYPE: unsigned int
      IDENTIFIER u
  FUNCTION DEFINITION
    RETURN TYPE: static union Word
    IDENTIFIER step
    PARAMETERS
      VAR_DECL
        TYPE: union Word
        IDENTIFIER w
    BLOCK
      ASSIGNMENT (+=)
        DOT_ACCESS '.'
          IDENTIFIER w
          FIELD u
        NUMBER_LITERAL 3u
      RETURN
        IDENTIFIER w
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: union Word
        IDENTIFIER w
      ASSIGNMENT (=)
        DOT_ACCESS '.'
          IDENTIFIER w
          FIELD i
        NUMBER_LITERAL 10
      ASSIGNMENT (=)
        IDENTIFIER w
        FUNCTION CALL
          IDENTIFIER step
          ARGUMENTS
            IDENTIFIER w
      RETURN
        CAST_EXPRESSION
                    CAST TYPE: int
          DOT_ACCESS '.'
            IDENTIFIER w
            FIELD u
