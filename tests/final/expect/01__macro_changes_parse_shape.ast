AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            BINARY EXPRESSION '+'
              TERNARY_EXPRESSION
                IDENTIFIER x
                NUMBER_LITERAL 10
                NUMBER_LITERAL 20
              NUMBER_LITERAL 2
      RETURN
        IDENTIFIER y
