AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER ub_shift_left
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            BINARY EXPRESSION '<<'
              IDENTIFIER x
              NUMBER_LITERAL 3
      IF_STATEMENT
        BINARY EXPRESSION '<'
          IDENTIFIER y
          NUMBER_LITERAL 0
        BLOCK
          RETURN
            IDENTIFIER y
      RETURN
        IDENTIFIER x
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 0x20000000
      RETURN
        FUNCTION CALL
          IDENTIFIER ub_shift_left
          ARGUMENTS
            IDENTIFIER seed
