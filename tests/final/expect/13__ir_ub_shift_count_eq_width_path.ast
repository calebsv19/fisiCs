AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER ub_shift_eq_width
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
      VAR_DECL
        TYPE: int
        IDENTIFIER s
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            BINARY EXPRESSION '<<'
              IDENTIFIER x
              IDENTIFIER s
      IF_STATEMENT
        BINARY EXPRESSION '=='
          IDENTIFIER y
          NUMBER_LITERAL 0
        BLOCK
          RETURN
            IDENTIFIER x
      RETURN
        IDENTIFIER y
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER shift
          = 
            CAST_EXPRESSION
                            CAST TYPE: int
              BINARY EXPRESSION '*'
                SIZEOF
                                    PARSED_TYPE int
                NUMBER_LITERAL 8
      RETURN
        FUNCTION CALL
          IDENTIFIER ub_shift_eq_width
          ARGUMENTS
            IDENTIFIER seed
            IDENTIFIER shift
