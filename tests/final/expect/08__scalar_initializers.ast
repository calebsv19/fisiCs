AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: double
        IDENTIFIER b
          = NUMBER_LITERAL 2.5
      VAR_DECL
        TYPE: char
        IDENTIFIER c
          = NUMBER_LITERAL 300
      RETURN
        BINARY EXPRESSION '+'
          BINARY EXPRESSION '+'
            IDENTIFIER a
            CAST_EXPRESSION
                            CAST TYPE: int
              IDENTIFIER b
          IDENTIFIER c
