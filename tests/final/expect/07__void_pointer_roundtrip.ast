AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 7
      VAR_DECL
        TYPE: void*
        IDENTIFIER vp
          = 
            UNARY EXPRESSION '&' (prefix)
              IDENTIFIER x
      VAR_DECL
        TYPE: int*
        IDENTIFIER ip
          = IDENTIFIER vp
      RETURN
        UNARY EXPRESSION '*' (prefix)
          IDENTIFIER ip
