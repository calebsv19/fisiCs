AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            BINARY EXPRESSION '+'
              SIZEOF
                                IDENTIFIER x
              NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER z
          = 
            BINARY EXPRESSION '+'
              SIZEOF
                                PARSED_TYPE int
              NUMBER_LITERAL 2
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER y
          IDENTIFIER z
