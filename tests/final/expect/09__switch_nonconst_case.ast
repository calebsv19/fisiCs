AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 2
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = NUMBER_LITERAL 1
      SWITCH
        IDENTIFIER x
        CASE
          IDENTIFIER y
          RETURN
            NUMBER_LITERAL 1
        CASE
          DEFAULT
          RETURN
            NUMBER_LITERAL 0
