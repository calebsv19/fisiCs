AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER sum
          = NUMBER_LITERAL 0
      FOR_LOOP
        VAR_DECL
          TYPE: int
          IDENTIFIER i
            = NUMBER_LITERAL 0
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 6
        UNARY EXPRESSION '++' (prefix)
          IDENTIFIER i
        BLOCK
          SWITCH
            BINARY EXPRESSION '&'
              IDENTIFIER i
              NUMBER_LITERAL 1
            CASE
              NUMBER_LITERAL 0
              ASSIGNMENT (+=)
                IDENTIFIER sum
                NUMBER_LITERAL 1
              CONTINUE
            CASE
              DEFAULT
              ASSIGNMENT (+=)
                IDENTIFIER sum
                NUMBER_LITERAL 10
              BREAK
          ASSIGNMENT (+=)
            IDENTIFIER sum
            NUMBER_LITERAL 100
      RETURN
        IDENTIFIER sum
