; ModuleID = 'compiler_module'
source_filename = "compiler_module"
target datalayout = "e-p:64:64:64-i8:8-i16:16-i32:32-i64:64-f32:32-f64:64-f64:64-a:0:128-n8:16:32:64"

@__stdinp = external global ptr, align 8
@__LDBL_MIN__ = internal global double 0.000000e+00, align 8
@__stdoutp = external global ptr, align 8
@NULL = internal global ptr null, align 8
@sys_errlist = external global ptr, align 8
@__FLT_MIN__ = internal global float 0.000000e+00, align 4
@__stderrp = external global ptr, align 8
@__DBL_MIN__ = internal global double 0.000000e+00, align 8
@sys_nerr = external global i32, align 4
@.str.0 = private unnamed_addr constant [7 x i8] c"second\00"
@.str.1 = private unnamed_addr constant [21 x i8] c"%.6f %.6f %.6f %.6f\0A\00"

define i32 @main() {
entry:
  %average_power = alloca double, align 8
  %charge_ah = alloca double, align 8
  %energy_j = alloca double, align 8
  %distance_m = alloca double, align 8
  %burn_time_s = alloca double, align 8
  %reserve_mah = alloca double, align 8
  %thrust_lbf = alloca double, align 8
  %dt_ms = alloca double, align 8
  %speed_fps = alloca double, align 8
  store double 9.600000e+01, ptr %speed_fps, align 8
  store double 1.250000e+03, ptr %dt_ms, align 8
  store double 1.250000e+01, ptr %thrust_lbf, align 8
  store double 3.600000e+03, ptr %reserve_mah, align 8
  %dt_ms1 = load double, ptr %dt_ms, align 8
  %fisics.unit.to_canonical.scale = fmul double %dt_ms1, 1.000000e-03
  store double %fisics.unit.to_canonical.scale, ptr %burn_time_s, align 8
  %speed_fps2 = load double, ptr %speed_fps, align 8
  %dt_ms3 = load double, ptr %dt_ms, align 8
  %calltmp = call double @probe_state_bridge_distance(double %speed_fps2, double %dt_ms3)
  store double %calltmp, ptr %distance_m, align 8
  %thrust_lbf4 = load double, ptr %thrust_lbf, align 8
  %distance_m5 = load double, ptr %distance_m, align 8
  %calltmp6 = call double @probe_state_bridge_energy(double %thrust_lbf4, double %distance_m5)
  store double %calltmp6, ptr %energy_j, align 8
  %reserve_mah7 = load double, ptr %reserve_mah, align 8
  %calltmp8 = call double @probe_state_bridge_charge(double %reserve_mah7)
  store double %calltmp8, ptr %charge_ah, align 8
  %energy_j9 = load double, ptr %energy_j, align 8
  %burn_time_s10 = load double, ptr %burn_time_s, align 8
  %fdivtmp = fdiv double %energy_j9, %burn_time_s10
  store double %fdivtmp, ptr %average_power, align 8
  %distance_m11 = load double, ptr %distance_m, align 8
  %energy_j12 = load double, ptr %energy_j, align 8
  %average_power13 = load double, ptr %average_power, align 8
  %charge_ah14 = load double, ptr %charge_ah, align 8
  %calltmp15 = call i32 (ptr, ...) @printf(ptr @.str.1, double %distance_m11, double %energy_j12, double %average_power13, double %charge_ah14)
  ret i32 0
}

declare double @fisics_convert_unit(...)

declare double @probe_state_bridge_distance(double %0, double %1)

declare double @probe_state_bridge_energy(double %0, double %1)

declare double @probe_state_bridge_charge(double %0)

declare i32 @printf(ptr %0, ...)
