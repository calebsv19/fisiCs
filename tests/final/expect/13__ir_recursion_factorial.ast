AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: static int
    IDENTIFIER fact
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER n
    BLOCK
      IF_STATEMENT
        BINARY EXPRESSION '<='
          IDENTIFIER n
          NUMBER_LITERAL 1
        BLOCK
          RETURN
            NUMBER_LITERAL 1
      RETURN
        BINARY EXPRESSION '*'
          IDENTIFIER n
          FUNCTION CALL
            IDENTIFIER fact
            ARGUMENTS
              BINARY EXPRESSION '-'
                IDENTIFIER n
                NUMBER_LITERAL 1
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      RETURN
        FUNCTION CALL
          IDENTIFIER fact
          ARGUMENTS
            NUMBER_LITERAL 5
