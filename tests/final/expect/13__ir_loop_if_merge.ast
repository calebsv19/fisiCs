AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER i
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER acc
          = NUMBER_LITERAL 0
      WHILE_LOOP
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 6
        BLOCK
          IF_STATEMENT
            BINARY EXPRESSION '=='
              BINARY EXPRESSION '&'
                IDENTIFIER i
                NUMBER_LITERAL 1
              NUMBER_LITERAL 0
            BLOCK
              ASSIGNMENT (+=)
                IDENTIFIER acc
                IDENTIFIER i
          ELSE_STATEMENT
            BLOCK
              ASSIGNMENT (+=)
                IDENTIFIER acc
                BINARY EXPRESSION '*'
                  IDENTIFIER i
                  NUMBER_LITERAL 2
          UNARY EXPRESSION '++' (prefix)
            IDENTIFIER i
      RETURN
        IDENTIFIER acc
