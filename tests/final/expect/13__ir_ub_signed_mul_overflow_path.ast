AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER overflow_mul
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            BINARY EXPRESSION '*'
              IDENTIFIER x
              NUMBER_LITERAL 3
      IF_STATEMENT
        BINARY EXPRESSION '!='
          BINARY EXPRESSION '/'
            IDENTIFIER y
            NUMBER_LITERAL 3
          IDENTIFIER x
        BLOCK
          RETURN
            IDENTIFIER y
      RETURN
        IDENTIFIER x
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 1073741824
      RETURN
        FUNCTION CALL
          IDENTIFIER overflow_mul
          ARGUMENTS
            IDENTIFIER seed
