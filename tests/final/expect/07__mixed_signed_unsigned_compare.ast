AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = 
            UNARY EXPRESSION '-' (prefix)
              NUMBER_LITERAL 1
      VAR_DECL
        TYPE: unsigned int
        IDENTIFIER b
          = NUMBER_LITERAL 1u
      VAR_DECL
        TYPE: int
        IDENTIFIER ok
          = 
            BINARY EXPRESSION '<'
              IDENTIFIER a
              IDENTIFIER b
      RETURN
        IDENTIFIER ok
