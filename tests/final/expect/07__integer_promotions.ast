AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: _Bool
        IDENTIFIER b
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: char
        IDENTIFIER c
          = NUMBER_LITERAL 2
      VAR_DECL
        TYPE: short int
        IDENTIFIER s
          = NUMBER_LITERAL 3
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = 
            BINARY EXPRESSION '+'
              BINARY EXPRESSION '+'
                IDENTIFIER b
                IDENTIFIER c
              IDENTIFIER s
      RETURN
        IDENTIFIER x
