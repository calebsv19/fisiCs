AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER i
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER acc
          = NUMBER_LITERAL 0
      LABEL: start
        IF_STATEMENT
          BINARY EXPRESSION '>='
            IDENTIFIER i
            NUMBER_LITERAL 5
          BLOCK
            RETURN
              IDENTIFIER acc
      ASSIGNMENT (+=)
        IDENTIFIER acc
        BINARY EXPRESSION '*'
          IDENTIFIER i
          NUMBER_LITERAL 3
      UNARY EXPRESSION '++' (prefix)
        IDENTIFIER i
      GOTO
        LABEL start
