AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER i
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER sum
          = NUMBER_LITERAL 0
      FOR_LOOP
        BLOCK
          BREAK
      FOR_LOOP
        ASSIGNMENT (=)
          IDENTIFIER i
          NUMBER_LITERAL 0
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 2
        BLOCK
          ASSIGNMENT (+=)
            IDENTIFIER sum
            IDENTIFIER i
          UNARY EXPRESSION '++' (postfix)
            IDENTIFIER i
      FOR_LOOP
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 4
        UNARY EXPRESSION '++' (postfix)
          IDENTIFIER i
        BLOCK
          ASSIGNMENT (+=)
            IDENTIFIER sum
            IDENTIFIER i
      RETURN
        IDENTIFIER sum
