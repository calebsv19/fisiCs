AST:
PROGRAM
  VAR_DECL
    TYPE: volatile int
    IDENTIFIER gv
      = NUMBER_LITERAL 3
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int*
        IDENTIFIER p
          = 
            UNARY EXPRESSION '&' (prefix)
              IDENTIFIER gv
      ASSIGNMENT (=)
        UNARY EXPRESSION '*' (prefix)
          IDENTIFIER p
        BINARY EXPRESSION '+'
          UNARY EXPRESSION '*' (prefix)
            IDENTIFIER p
          NUMBER_LITERAL 1
      RETURN
        IDENTIFIER gv
