AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = 
            BINARY EXPRESSION '+'
              FUNCTION CALL
                IDENTIFIER missing
              NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = 
            BINARY EXPRESSION '+'
              FUNCTION CALL
                IDENTIFIER missing
              NUMBER_LITERAL 1
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          IDENTIFIER b
