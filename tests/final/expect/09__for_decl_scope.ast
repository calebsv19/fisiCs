AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER sum
          = NUMBER_LITERAL 0
      FOR_LOOP
        VAR_DECL
          TYPE: int
          IDENTIFIER i
            = NUMBER_LITERAL 0
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 3
        UNARY EXPRESSION '++' (postfix)
          IDENTIFIER i
        BLOCK
          ASSIGNMENT (+=)
            IDENTIFIER sum
            IDENTIFIER i
      RETURN
        IDENTIFIER sum
