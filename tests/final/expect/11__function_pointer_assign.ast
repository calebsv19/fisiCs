AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER fi
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      RETURN
        IDENTIFIER x
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER fd
    PARAMETERS
      VAR_DECL
        TYPE: double
        IDENTIFIER x
    BLOCK
      RETURN
        CAST_EXPRESSION
                    CAST TYPE: int
          IDENTIFIER x
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int (*)(int) (int)
        IDENTIFIER fp
          = IDENTIFIER fi
      VAR_DECL
        TYPE: int (*)(double) (double)
        IDENTIFIER gp
          = IDENTIFIER fd
      ASSIGNMENT (=)
        IDENTIFIER fp
        IDENTIFIER gp
      RETURN
        FUNCTION CALL
          IDENTIFIER fp
          ARGUMENTS
            NUMBER_LITERAL 1
