AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int [NUMBER_LITERAL 2]
        IDENTIFIER arr
            = NUMBER_LITERAL 0

      VAR_DECL
        TYPE: int*
        IDENTIFIER p
          = IDENTIFIER arr
      VAR_DECL
        TYPE: int*
        IDENTIFIER q
          = 
            BINARY EXPRESSION '+'
              IDENTIFIER arr
              NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER ok
          = 
            BINARY EXPRESSION '&&'
              BINARY EXPRESSION '!='
                IDENTIFIER p
                NUMBER_LITERAL 0
              BINARY EXPRESSION '>'
                IDENTIFIER q
                IDENTIFIER p
      RETURN
        IDENTIFIER ok
