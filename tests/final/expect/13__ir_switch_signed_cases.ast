AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = 
            UNARY EXPRESSION '-' (prefix)
              NUMBER_LITERAL 3
      VAR_DECL
        TYPE: int
        IDENTIFIER out
          = NUMBER_LITERAL 0
      SWITCH
        IDENTIFIER x
        CASE
          UNARY EXPRESSION '-' (prefix)
            NUMBER_LITERAL 5
          ASSIGNMENT (=)
            IDENTIFIER out
            NUMBER_LITERAL 50
          BREAK
        CASE
          UNARY EXPRESSION '-' (prefix)
            NUMBER_LITERAL 3
          ASSIGNMENT (=)
            IDENTIFIER out
            NUMBER_LITERAL 30
          BREAK
        CASE
          NUMBER_LITERAL 2
          ASSIGNMENT (=)
            IDENTIFIER out
            NUMBER_LITERAL 2
          BREAK
        CASE
          DEFAULT
          ASSIGNMENT (=)
            IDENTIFIER out
            NUMBER_LITERAL 9
          BREAK
      RETURN
        IDENTIFIER out
