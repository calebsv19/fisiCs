AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = NUMBER_LITERAL 0
      FOR_LOOP
        VAR_DECL
          TYPE: int
          IDENTIFIER i
            = NUMBER_LITERAL 0
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 8
        UNARY EXPRESSION '++' (prefix)
          IDENTIFIER i
        BLOCK
          IF_STATEMENT
            BINARY EXPRESSION '=='
              BINARY EXPRESSION '&'
                IDENTIFIER i
                NUMBER_LITERAL 1
              NUMBER_LITERAL 0
            BLOCK
              CONTINUE
          IF_STATEMENT
            BINARY EXPRESSION '>'
              IDENTIFIER i
              NUMBER_LITERAL 5
            BLOCK
              BREAK
          ASSIGNMENT (+=)
            IDENTIFIER y
            IDENTIFIER i
          ASSIGNMENT (+=)
            IDENTIFIER x
            IDENTIFIER y
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER x
          IDENTIFIER y
