AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER ub_postinc
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            UNARY EXPRESSION '++' (postfix)
              IDENTIFIER x
      IF_STATEMENT
        BINARY EXPRESSION '<'
          IDENTIFIER x
          IDENTIFIER y
        BLOCK
          RETURN
            BINARY EXPRESSION '^'
              IDENTIFIER x
              IDENTIFIER y
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER x
          IDENTIFIER y
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 2147483647
      RETURN
        FUNCTION CALL
          IDENTIFIER ub_postinc
          ARGUMENTS
            IDENTIFIER seed
