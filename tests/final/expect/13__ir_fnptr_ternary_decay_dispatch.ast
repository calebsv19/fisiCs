AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER inc
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER x
          NUMBER_LITERAL 1
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER dec
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      RETURN
        BINARY EXPRESSION '-'
          IDENTIFIER x
          NUMBER_LITERAL 1
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER pick
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int (*)(int)
        IDENTIFIER fp
          = 
            TERNARY_EXPRESSION
              IDENTIFIER pick
              IDENTIFIER inc
              IDENTIFIER dec
      RETURN
        BINARY EXPRESSION '!='
          FUNCTION CALL
            IDENTIFIER fp
            ARGUMENTS
              NUMBER_LITERAL 4
          NUMBER_LITERAL 5
