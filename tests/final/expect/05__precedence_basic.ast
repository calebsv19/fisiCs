AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = 
            BINARY EXPRESSION '<<'
              BINARY EXPRESSION '+'
                NUMBER_LITERAL 1
                BINARY EXPRESSION '*'
                  NUMBER_LITERAL 2
                  NUMBER_LITERAL 3
              NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = 
            BINARY EXPRESSION '||'
              BINARY EXPRESSION '&&'
                BINARY EXPRESSION '<'
                  IDENTIFIER a
                  NUMBER_LITERAL 10
                BINARY EXPRESSION '!='
                  IDENTIFIER a
                  NUMBER_LITERAL 5
              BINARY EXPRESSION '=='
                IDENTIFIER a
                NUMBER_LITERAL 7
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          IDENTIFIER b
