AST:
PROGRAM
  TYPEDEF
        TYPE: int
        Alias:     IDENTIFIER S
  STRUCT
        Name:     IDENTIFIER S
    VAR_DECL
      TYPE: int
      IDENTIFIER v
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: S
        IDENTIFIER a
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: struct S
        IDENTIFIER b
            = NUMBER_LITERAL 2

      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          DOT_ACCESS '.'
            IDENTIFIER b
            FIELD v
