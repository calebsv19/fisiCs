AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = NUMBER_LITERAL 2
      VAR_DECL
        TYPE: int
        IDENTIFIER z
          = NUMBER_LITERAL 0
      ASSIGNMENT (=)
        IDENTIFIER z
        TERNARY_EXPRESSION
          BINARY EXPRESSION '<'
            IDENTIFIER x
            IDENTIFIER y
          BINARY EXPRESSION '+'
            IDENTIFIER x
            IDENTIFIER y
          BINARY EXPRESSION '-'
            IDENTIFIER x
            IDENTIFIER y
      ASSIGNMENT (+=)
        IDENTIFIER z
        TERNARY_EXPRESSION
          BINARY EXPRESSION '&&'
            IDENTIFIER x
            IDENTIFIER y
          NUMBER_LITERAL 3
          NUMBER_LITERAL 4
      RETURN
        IDENTIFIER z
