AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 5
      VAR_DECL
        TYPE: int*
        IDENTIFIER p
          = 
            UNARY EXPRESSION '&' (prefix)
              IDENTIFIER x
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            UNARY EXPRESSION '*' (prefix)
              IDENTIFIER p
      RETURN
        BINARY EXPRESSION '-'
          IDENTIFIER y
          NUMBER_LITERAL 5
