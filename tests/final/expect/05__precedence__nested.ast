AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 3
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = NUMBER_LITERAL 4
      VAR_DECL
        TYPE: int
        IDENTIFIER c
          = NUMBER_LITERAL 5
      VAR_DECL
        TYPE: int
        IDENTIFIER v
          = 
            BINARY EXPRESSION '+'
              BINARY EXPRESSION '/'
                BINARY EXPRESSION '*'
                  BINARY EXPRESSION '+'
                    IDENTIFIER a
                    IDENTIFIER b
                  BINARY EXPRESSION '-'
                    IDENTIFIER c
                    IDENTIFIER a
                BINARY EXPRESSION '-'
                  IDENTIFIER b
                  NUMBER_LITERAL 2
              TERNARY_EXPRESSION
                IDENTIFIER a
                IDENTIFIER b
                IDENTIFIER c
      RETURN
        TERNARY_EXPRESSION
          BINARY EXPRESSION '=='
            IDENTIFIER v
            NUMBER_LITERAL 11
          NUMBER_LITERAL 0
          NUMBER_LITERAL 1
