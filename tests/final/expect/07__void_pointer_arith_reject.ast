AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: void*
        IDENTIFIER vp
          = NUMBER_LITERAL 0
      ASSIGNMENT (=)
        IDENTIFIER vp
        BINARY EXPRESSION '+'
          IDENTIFIER vp
          NUMBER_LITERAL 1
      RETURN
        BINARY EXPRESSION '!='
          IDENTIFIER vp
          NUMBER_LITERAL 0
