AST:
PROGRAM
  STRUCT
        Name:     IDENTIFIER Pair
    VAR_DECL
      TYPE: int
      IDENTIFIER a
    VAR_DECL
      TYPE: long int
      IDENTIFIER b
  FUNCTION DEFINITION
    RETURN TYPE: static struct Pair
    IDENTIFIER tweak
    PARAMETERS
      VAR_DECL
        TYPE: struct Pair
        IDENTIFIER p
      VAR_DECL
        TYPE: int
        IDENTIFIER d
    BLOCK
      ASSIGNMENT (+=)
        DOT_ACCESS '.'
          IDENTIFIER p
          FIELD a
        IDENTIFIER d
      ASSIGNMENT (+=)
        DOT_ACCESS '.'
          IDENTIFIER p
          FIELD b
        BINARY EXPRESSION '*'
          CAST_EXPRESSION
                        CAST TYPE: long int
            IDENTIFIER d
          NUMBER_LITERAL 10
      RETURN
        IDENTIFIER p
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: struct Pair
        IDENTIFIER p
            = NUMBER_LITERAL 2

            = NUMBER_LITERAL 5

      VAR_DECL
        TYPE: struct Pair
        IDENTIFIER q
          = 
            FUNCTION CALL
              IDENTIFIER tweak
              ARGUMENTS
                IDENTIFIER p
                NUMBER_LITERAL 3
      RETURN
        BINARY EXPRESSION '+'
          DOT_ACCESS '.'
            IDENTIFIER q
            FIELD a
          CAST_EXPRESSION
                        CAST TYPE: int
            DOT_ACCESS '.'
              IDENTIFIER q
              FIELD b
