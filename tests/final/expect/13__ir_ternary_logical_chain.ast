AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER c
          = NUMBER_LITERAL 2
      VAR_DECL
        TYPE: int
        IDENTIFIER out
          = 
            BINARY EXPRESSION '+'
              TERNARY_EXPRESSION
                IDENTIFIER a
                BINARY EXPRESSION '+'
                  IDENTIFIER b
                  NUMBER_LITERAL 3
                BINARY EXPRESSION '+'
                  IDENTIFIER c
                  NUMBER_LITERAL 5
              TERNARY_EXPRESSION
                BINARY EXPRESSION '&&'
                  IDENTIFIER b
                  IDENTIFIER c
                NUMBER_LITERAL 7
                NUMBER_LITERAL 9
      RETURN
        IDENTIFIER out
