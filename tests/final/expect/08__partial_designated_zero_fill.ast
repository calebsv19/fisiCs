AST:
PROGRAM
  STRUCT
        Name:     IDENTIFIER S
    VAR_DECL
      TYPE: int
      IDENTIFIER a
    VAR_DECL
      TYPE: int
      IDENTIFIER b
    VAR_DECL
      TYPE: int
      IDENTIFIER c
  VAR_DECL
    TYPE: struct S
    IDENTIFIER s
        .b = NUMBER_LITERAL 7

  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      RETURN
        BINARY EXPRESSION '+'
          BINARY EXPRESSION '+'
            DOT_ACCESS '.'
              IDENTIFIER s
              FIELD a
            DOT_ACCESS '.'
              IDENTIFIER s
              FIELD b
          DOT_ACCESS '.'
            IDENTIFIER s
            FIELD c
