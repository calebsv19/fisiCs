AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER ub_preinc
    PARAMETERS
      VAR_DECL
        TYPE: int
        IDENTIFIER x
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            UNARY EXPRESSION '++' (prefix)
              IDENTIFIER x
      IF_STATEMENT
        BINARY EXPRESSION '<'
          IDENTIFIER y
          NUMBER_LITERAL 0
        BLOCK
          RETURN
            IDENTIFIER y
      RETURN
        IDENTIFIER x
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: volatile int
        IDENTIFIER seed
          = NUMBER_LITERAL 2147483647
      RETURN
        FUNCTION CALL
          IDENTIFIER ub_preinc
          ARGUMENTS
            IDENTIFIER seed
