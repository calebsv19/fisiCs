  %n3 = load i32, ptr %n, align 4
  %cmptmp = icmp ult i32 %i2, %n3
  %cmp.int = zext i1 %cmptmp to i32
  %forcond4 = icmp ne i32 %cmp.int, 0
  br i1 %forcond4, label %forbody, label %forend

forbody:                                          ; preds = %forcond
  %lane = alloca i32, align 4
  %f0 = alloca ptr, align 8
  %f1 = alloca ptr, align 8
  %x = alloca i32, align 4
  %y = alloca i32, align 4
