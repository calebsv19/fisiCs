            IDENTIFIER f1
            ARRAY_ACCESS
              DOT_ACCESS '.'
                POINTER_ACCESS '->'
                  IDENTIFIER cur
                  FIELD frame
                FIELD ops
              BINARY EXPRESSION '%'
                BINARY EXPRESSION '+'
                  IDENTIFIER lane
                  NUMBER_LITERAL 1u
                NUMBER_LITERAL 3u
          ASSIGNMENT (=)
            IDENTIFIER x
            FUNCTION CALL
              IDENTIFIER f0
              ARGUMENTS
                ARRAY_ACCESS
                  IDENTIFIER values
                  IDENTIFIER i
                BINARY EXPRESSION '+'
                  DOT_ACCESS '.'
                    POINTER_ACCESS '->'
                      IDENTIFIER cur
                      FIELD frame
                    FIELD seed
                  POINTER_ACCESS '->'
                    IDENTIFIER cur
                    FIELD bias
