  store i32 %modtmp, ptr %lane, align 4
  %cur9 = load ptr, ptr %cur, align 8
  %fieldPtr10 = getelementptr inbounds nuw %Layer, ptr %cur9, i32 0, i32 0
  %fieldPtr11 = getelementptr inbounds nuw %__anon_struct_1_12, ptr %fieldPtr10, i32 0, i32 1
  %lane12 = load i32, ptr %lane, align 4
  %array.idx64 = sext i32 %lane12 to i64
  %arrayElemPtr = getelementptr [3 x ptr], ptr %fieldPtr11, i64 0, i64 %array.idx64
  %arrayLoad = load ptr, ptr %arrayElemPtr, align 8
  store ptr %arrayLoad, ptr %f0, align 8
  %cur13 = load ptr, ptr %cur, align 8
  %fieldPtr14 = getelementptr inbounds nuw %Layer, ptr %cur13, i32 0, i32 0
  %fieldPtr15 = getelementptr inbounds nuw %__anon_struct_1_12, ptr %fieldPtr14, i32 0, i32 1
  %lane16 = load i32, ptr %lane, align 4
  %addtmp = add i32 %lane16, 1
  %modtmp17 = urem i32 %addtmp, 3
  %array.idx6418 = sext i32 %modtmp17 to i64
  %arrayElemPtr19 = getelementptr [3 x ptr], ptr %fieldPtr15, i64 0, i64 %array.idx6418
  %arrayLoad20 = load ptr, ptr %arrayElemPtr19, align 8
  store ptr %arrayLoad20, ptr %f1, align 8
  %f021 = load ptr, ptr %f0, align 8
  %array.ptr.load = load ptr, ptr %values, align 8
  %i22 = load i32, ptr %i, align 4
  %array.idx6423 = sext i32 %i22 to i64
  %arrayElemPtr24 = getelementptr i32, ptr %array.ptr.load, i64 %array.idx6423
  %arrayLoad25 = load i32, ptr %arrayElemPtr24, align 4
  %cur26 = load ptr, ptr %cur, align 8
  %fieldPtr27 = getelementptr inbounds nuw %Layer, ptr %cur26, i32 0, i32 0
  %fieldPtr28 = getelementptr inbounds nuw %__anon_struct_1_12, ptr %fieldPtr27, i32 0, i32 0
  %dot_field29 = load i32, ptr %fieldPtr28, align 4
  %cur30 = load ptr, ptr %cur, align 8
  %fieldPtr31 = getelementptr inbounds nuw %Layer, ptr %cur30, i32 0, i32 1
  %ptr_field = load i32, ptr %fieldPtr31, align 4
  %addtmp32 = add i32 %dot_field29, %ptr_field
  %calltmp = call i32 %f021(i32 %arrayLoad25, i32 %addtmp32)
  store i32 %calltmp, ptr %x, align 4
  %f133 = load ptr, ptr %f1, align 8
  %x34 = load i32, ptr %x, align 4
  %i35 = load i32, ptr %i, align 4
  %cur36 = load ptr, ptr %cur, align 8
  %fieldPtr37 = getelementptr inbounds nuw %Layer, ptr %cur36, i32 0, i32 1
  %ptr_field38 = load i32, ptr %fieldPtr37, align 4
  %addtmp39 = add i32 %i35, %ptr_field38
  %calltmp40 = call i32 %f133(i32 %x34, i32 %addtmp39)
  store i32 %calltmp40, ptr %y, align 4
  %acc41 = load i32, ptr %acc, align 4
  %multmp = mul i32 %acc41, 131
  %y42 = load i32, ptr %y, align 4
  %cur43 = load ptr, ptr %cur, align 8
  %fieldPtr44 = getelementptr inbounds nuw %Layer, ptr %cur43, i32 0, i32 1
  %ptr_field45 = load i32, ptr %fieldPtr44, align 4
  %multmp46 = mul i32 %ptr_field45, 7
  %addtmp47 = add i32 %y42, %multmp46
  %xortmp48 = xor i32 %multmp, %addtmp47
  store i32 %xortmp48, ptr %acc, align 4
  %i49 = load i32, ptr %i, align 4
  %andtmp = and i32 %i49, 1
  %cmptmp50 = icmp ne i32 %andtmp, 0
  %cmp.int51 = zext i1 %cmptmp50 to i32
  %ifcond52 = icmp ne i32 %cmp.int51, 0
