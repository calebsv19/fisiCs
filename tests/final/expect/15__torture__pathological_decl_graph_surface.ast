  %ptrcmp = icmp eq i64 %ptr.cmp.lhs, 0
  %ptrcmp.int = zext i1 %ptrcmp to i32
  %ifcond = icmp ne i32 %ptrcmp.int, 0
  br i1 %ifcond, label %then, label %ifcont

forinc:                                           ; preds = %ifcont54
  %unary.load = load i32, ptr %i, align 4
  %unary.inc = add i32 %unary.load, 1
  store i32 %unary.inc, ptr %i, align 4
  br label %forcond

forend:                                           ; preds = %then, %forcond
  %acc59 = load i32, ptr %acc, align 4
  ret i32 %acc59

then:                                             ; preds = %forbody
  br label %forend

ifcont:                                           ; preds = %forbody
  %cur6 = load ptr, ptr %cur, align 8
  %fieldPtr = getelementptr inbounds nuw %Layer, ptr %cur6, i32 0, i32 0
  %fieldPtr7 = getelementptr inbounds nuw %__anon_struct_1_12, ptr %fieldPtr, i32 0, i32 0
