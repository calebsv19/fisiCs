AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = NUMBER_LITERAL 2
      VAR_DECL
        TYPE: int
        IDENTIFIER out
          = NUMBER_LITERAL 0
      SWITCH
        IDENTIFIER x
        CASE
          NUMBER_LITERAL 0
          SWITCH
            IDENTIFIER y
            CASE
              NUMBER_LITERAL 1
              ASSIGNMENT (=)
                IDENTIFIER out
                NUMBER_LITERAL 11
              BREAK
            CASE
              NUMBER_LITERAL 2
              ASSIGNMENT (=)
                IDENTIFIER out
                NUMBER_LITERAL 22
              BREAK
            CASE
              DEFAULT
              ASSIGNMENT (=)
                IDENTIFIER out
                NUMBER_LITERAL 33
              BREAK
          BREAK
        CASE
          DEFAULT
          ASSIGNMENT (=)
            IDENTIFIER out
            NUMBER_LITERAL 44
          BREAK
      RETURN
        IDENTIFIER out
