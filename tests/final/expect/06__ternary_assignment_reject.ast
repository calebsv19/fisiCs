AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 1
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = NUMBER_LITERAL 2
      VAR_DECL
        TYPE: int
        IDENTIFIER c
          = NUMBER_LITERAL 0
      ASSIGNMENT (=)
        TERNARY_EXPRESSION
          IDENTIFIER c
          IDENTIFIER a
          IDENTIFIER b
        NUMBER_LITERAL 3
      RETURN
        BINARY EXPRESSION '+'
          IDENTIFIER a
          IDENTIFIER b
