PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int [2]
        IDENTIFIER arr
            = NUMBER_LITERAL 1

            = NUMBER_LITERAL 2

      VAR_DECL
        TYPE: int*
