AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 0
      GOTO
        LABEL skip
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = NUMBER_LITERAL 1
      LABEL: skip
        RETURN
          IDENTIFIER x
