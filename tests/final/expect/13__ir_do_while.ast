AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER i
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER acc
          = NUMBER_LITERAL 0
      DO_WHILE_LOOP
        BLOCK
          ASSIGNMENT (+=)
            IDENTIFIER acc
            IDENTIFIER i
          UNARY EXPRESSION '++' (postfix)
            IDENTIFIER i
        BINARY EXPRESSION '<'
          IDENTIFIER i
          NUMBER_LITERAL 4
      RETURN
        IDENTIFIER acc
