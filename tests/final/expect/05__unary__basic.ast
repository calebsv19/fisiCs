AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER x
          = NUMBER_LITERAL 3
      VAR_DECL
        TYPE: int
        IDENTIFIER y
          = 
            UNARY EXPRESSION '-' (prefix)
              IDENTIFIER x
      VAR_DECL
        TYPE: int
        IDENTIFIER z
          = 
            UNARY EXPRESSION '+' (prefix)
              IDENTIFIER x
      VAR_DECL
        TYPE: int
        IDENTIFIER ok
          = 
            UNARY EXPRESSION '!' (prefix)
              NUMBER_LITERAL 0
      RETURN
        TERNARY_EXPRESSION
          BINARY EXPRESSION '&&'
            BINARY EXPRESSION '&&'
              BINARY EXPRESSION '=='
                IDENTIFIER y
                UNARY EXPRESSION '-' (prefix)
                  NUMBER_LITERAL 3
              BINARY EXPRESSION '=='
                IDENTIFIER z
                NUMBER_LITERAL 3
            BINARY EXPRESSION '=='
              IDENTIFIER ok
              NUMBER_LITERAL 1
          NUMBER_LITERAL 0
          NUMBER_LITERAL 1
