AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 0
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = 
            COMMA_EXPRESSION (2 expressions)
              Expr[0]:
                ASSIGNMENT (=)
                  IDENTIFIER a
                  NUMBER_LITERAL 1
              Expr[1]:
                BINARY EXPRESSION '+'
                  IDENTIFIER a
                  NUMBER_LITERAL 2
      RETURN
        IDENTIFIER b
