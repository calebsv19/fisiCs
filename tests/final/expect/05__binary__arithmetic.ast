AST:
PROGRAM
  FUNCTION DEFINITION
    RETURN TYPE: int
    IDENTIFIER main
    PARAMETERS
      VAR_DECL
        TYPE: void
        IDENTIFIER __unnamed_param0
    BLOCK
      VAR_DECL
        TYPE: int
        IDENTIFIER a
          = NUMBER_LITERAL 10
      VAR_DECL
        TYPE: int
        IDENTIFIER b
          = NUMBER_LITERAL 3
      VAR_DECL
        TYPE: int
        IDENTIFIER c
          = 
            BINARY EXPRESSION '+'
              BINARY EXPRESSION '-'
                BINARY EXPRESSION '+'
                  IDENTIFIER a
                  IDENTIFIER b
                BINARY EXPRESSION '/'
                  IDENTIFIER a
                  IDENTIFIER b
              BINARY EXPRESSION '*'
                BINARY EXPRESSION '%'
                  IDENTIFIER a
                  IDENTIFIER b
                NUMBER_LITERAL 2
      RETURN
        TERNARY_EXPRESSION
          BINARY EXPRESSION '=='
            IDENTIFIER c
            NUMBER_LITERAL 12
          NUMBER_LITERAL 0
          NUMBER_LITERAL 1
